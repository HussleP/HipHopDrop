rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Polls — anyone authenticated can read; only server (admin SDK) writes
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions only
    }

    // Drops — authenticated read; server write only
    match /drops/{dropId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Articles — authenticated read; server write only
    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Interactions (likes, dislikes, comments) — authenticated users can read/write
    match /interactions/{contentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        // Anyone signed in can post; only the author can delete their own comment
        allow create: if request.auth != null
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 280;
        allow update: if request.auth != null; // for comment likes
        allow delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }
    }

    // Notification log — server write only, no client access
    match /notification_log/{logId} {
      allow read, write: if false;
    }
  }
}
